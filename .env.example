# docker-compose 가 읽는 환경변수 템플릿.
# 실제 사용 시 복사: cp .env.example .env && 수정
# .env 는 gitignore 대상.

# ─── 필수 ───
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── 권장 변경 ───
JWT_SECRET=please-change-to-a-32-byte-plus-random-secret-for-prod
# MariaDB (회사 PMS 스택 일치)
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too
